"live_activity.sample.alarm.note" = "Short 60-second countdown, no progress bar. Red communicates urgency — watch the timer count down in real time.";
"live_activity.sample.alarm.summary" = "A red 60-second countdown that grabs attention.";
"live_activity.sample.alarm.title" = "Alarm · 60 sec Countdown";
"live_activity.sample.all_fields.note" = "Every content-state field active at once: icon, live countdown, and progress bar. Confirms no layout collisions.";
"live_activity.sample.all_fields.summary" = "An icon, a timer, and a progress bar all at once.";
"live_activity.sample.all_fields.title" = "All Fields · Max Load";
"live_activity.sample.count_down.note" = "chronometer with when: 2700 and when_relative: true — a 45-minute countdown. The tinted timer bar (progress_bar_color) drains as time runs out.";
"live_activity.sample.count_down.summary" = "A 45-minute countdown, like a kitchen timer.";
"live_activity.sample.count_down.title" = "Oven Timer · 45 min Countdown";
"live_activity.sample.count_up.note" = "chronometer with when: 0 and when_relative: true resolves to \"now\", so the timer counts up — showing elapsed time since the activity started. No progress bar: an unbounded count-up has no end. To count up toward a target, use a negative when instead.";
"live_activity.sample.count_up.summary" = "A timer that counts up from zero.";
"live_activity.sample.count_up.title" = "Washing Machine · Count-Up Timer";
"live_activity.sample.count_up_target.note" = "A negative relative when (when: -1200) counts up toward the target: 0:00 → 20:00, the bar fills, and the timer freezes when it gets there.";
"live_activity.sample.count_up_target.summary" = "A timer that counts up toward a 20-minute goal.";
"live_activity.sample.count_up_target.title" = "Workout · Count-Up to 20 min";
"live_activity.sample.custom_colors.note" = "Sets a custom background and text color for the Lock Screen card. The Dynamic Island keeps its system-provided dark style.";
"live_activity.sample.custom_colors.summary" = "A card with your own background and text colors.";
"live_activity.sample.custom_colors.title" = "Custom Colors · Background + Text";
"live_activity.sample.delivery.note" = "message, criticalText, and icon all change on every update — no progress bar. The status category itself changes, not just a value.";
"live_activity.sample.delivery.summary" = "A package moving from shipped to delivered.";
"live_activity.sample.delivery.title" = "Package Delivery · All Text Fields";
"live_activity.sample.dishwasher.note" = "The only sample that tests start → update → end. After it ends, the final \"Done\" state lingers on the lock screen (up to 4 h).";
"live_activity.sample.dishwasher.summary" = "A full cycle that starts, runs, and finishes on its own.";
"live_activity.sample.dishwasher.title" = "Dishwasher · Full Lifecycle, Ends Itself";
"live_activity.sample.ev.note" = "Numeric percentage in criticalText updates alongside the progress bar; color shifts from green to yellow-green as the charge nears full.";
"live_activity.sample.ev.summary" = "A car battery charging up to full.";
"live_activity.sample.ev.title" = "EV Charging · Numeric %";
"live_activity.sample.media.note" = "Progress (playback position) and a live countdown (time left in track) update together. The track change resets both.";
"live_activity.sample.media.summary" = "A now-playing track with its position and time left.";
"live_activity.sample.media.title" = "Media Player · Progress + Timer";
"live_activity.sample.no_icon.note" = "No icon and no color, so the progress bar uses the default HA-blue tint. criticalText shows in the Dynamic Island compact trailing only.";
"live_activity.sample.no_icon.summary" = "A progress bar in the default color, with no icon.";
"live_activity.sample.no_icon.title" = "No Icon · Default Color";
"live_activity.sample.plain.note" = "Minimum viable layout — only the message field is set. Verifies the bare layout renders without icon, progress, or timer.";
"live_activity.sample.plain.summary" = "A basic message with nothing else.";
"live_activity.sample.plain.title" = "Plain Message";
"live_activity.sample.progress_direction.note" = "progress_bar_direction: decreasing flips the bar's fill: it shows what remains (progress_max − progress) and drains as progress rises. Percent text still shows the raw progress value. Also works on timer bars, e.g. increasing makes a countdown fill up instead of drain.";
"live_activity.sample.progress_direction.summary" = "A progress bar that drains instead of fills.";
"live_activity.sample.progress_direction.title" = "Battery · Decreasing Bar";
"live_activity.sample.rate_limit.note" = "Six updates 2 s apart. On iOS 18 the system renders ~one per 15 s — some are silently dropped and the counter skips. On the simulator and iOS 17 all six render.";
"live_activity.sample.rate_limit.summary" = "Rapid back-to-back updates to test how many show.";
"live_activity.sample.rate_limit.title" = "Rate Limit · 6 Rapid Updates";
"live_activity.sample.security.note" = "No progress bar — state is communicated entirely through color and icon. Escalates orange (motion) → red (person) → green (all clear).";
"live_activity.sample.security.summary" = "A security alert escalating, then all clear.";
"live_activity.sample.security.title" = "Security Escalation · Color + Icon";
"live_activity.sample.washing.note" = "Progress advances through five named stages; criticalText tracks the current stage. The icon swaps to a check on completion.";
"live_activity.sample.washing.summary" = "A wash cycle moving through each of its stages.";
"live_activity.sample.washing.title" = "Washing Machine · Stage Labels";
"live_activity.samples.animated_footer" = "Start drives the activity through several updates. Lock the screen to watch them live.";
"live_activity.samples.animated_title" = "Sample · Animated";
