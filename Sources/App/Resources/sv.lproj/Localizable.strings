"live_activity.privacy.message" = "Live Activity-innehåll är synligt på din låsskärm och Dynamic Island utan Face ID eller Touch ID. Välj vad du visar noggrant.";
"live_activity.sample.alarm.note" = "Kort nedräkning på 60 sekunder, utan förloppsindikator. Den röda färgen signalerar brådska – följ nedräkningen i realtid.";
"live_activity.sample.alarm.summary" = "En röd nedräkning på 60 sekunder som fångar uppmärksamheten.";
"live_activity.sample.alarm.title" = "Larm · 60 sekunders nedräkning";
"live_activity.sample.all_fields.note" = "Alla fält som visar innehållsstatus är aktiva samtidigt: ikon, realtidsnedräkning och förloppsindikator. Detta bekräftar att det inte förekommer några layoutkonflikter.";
"live_activity.sample.all_fields.summary" = "En ikon, en timer och en förloppsindikator på samma gång.";
"live_activity.sample.all_fields.title" = "Alla fält · Maximal belastning";
"live_activity.sample.count_down.note" = "kronometer med when: 2700 och when_relative: true — en nedräkning på 45 minuter. Den färgade tidsraden (progress_bar_color) töms i takt med att tiden rinner ut.";
"live_activity.sample.count_down.summary" = "En 45-minuters nedräkning, som en kökstimer.";
"live_activity.sample.count_down.title" = "Ugnstimer · 45 minuters nedräkning";
"live_activity.sample.count_up.note" = "En kronometer med `when`: 0 och `when_relative`: true tolkas som ”nu”, vilket innebär att timern räknar uppåt – och visar den tid som förflutit sedan aktiviteten startade. Ingen förloppsindikator: en obegränsad uppräkning har inget slut. Om du vill räkna upp mot ett mål ska du istället använda ett negativt `when`-värde.";
"live_activity.sample.count_up.summary" = "En timer som räknar uppåt från noll.";
"live_activity.sample.count_up.title" = "Tvättmaskin · Uppräkningstimer";
"live_activity.sample.count_up_target.note" = "Ett negativt relativvärde (när: -1200) räknar upp mot målet: 0:00 → 20:00, stapeln fylls och timern stannar när den når målet.";
"live_activity.sample.count_up_target.summary" = "En timer som räknar upp mot ett mål på 20 minuter.";
"live_activity.sample.count_up_target.title" = "Träning · Räkna upp till 20 min";
"live_activity.sample.custom_colors.note" = "Ställer in en anpassad bakgrunds- och textfärg för kortet på låsskärmen. Dynamic Island behåller sin systemstandardmässiga mörka stil.";
"live_activity.sample.custom_colors.summary" = "Ett kort med egna bakgrunds- och textfärger.";
"live_activity.sample.custom_colors.title" = "Anpassade färger · Bakgrund + text";
"live_activity.sample.delivery.note" = "meddelande, criticalText och ikon ändras vid varje uppdatering – ingen förloppsindikator. Det är själva statuskategorin som ändras, inte bara ett värde.";
"live_activity.sample.delivery.summary" = "Ett paket som övergår från statusen ”skickat” till ”levererat”.";
"live_activity.sample.delivery.title" = "Paketleverans · Alla textfält";
"live_activity.sample.dishwasher.note" = "Det enda exemplet där testet går igenom start → uppdatering → slut. När det är avslutat kvarstår det slutliga tillståndet ”Klar” på låsskärmen (upp till 4 timmar).";
"live_activity.sample.dishwasher.summary" = "En fullständig cykel som startar, pågår och avslutas av sig själv.";
"live_activity.sample.dishwasher.title" = "Diskmaskin · Hela livscykeln, avslutas automatiskt";
"live_activity.sample.ev.note" = "Den numeriska procentangivelsen i ”criticalText” uppdateras parallellt med förloppsindikatorn; färgen skiftar från grönt till gulgrönt när laddningen närmar sig full.";
"live_activity.sample.ev.summary" = "Ett bilbatteri som laddas upp till full kapacitet.";
"live_activity.sample.ev.title" = "Laddning av elbilar · Numeriskt %-tal";
"live_activity.sample.media.note" = "Förloppet (uppspelningsposition) och en live-nedräkning (tid kvar i spåret) uppdateras tillsammans. Spårbytet återställer båda.";
"live_activity.sample.media.summary" = "Ett spår som spelas nu med dess position och återstående tid.";
"live_activity.sample.media.title" = "Mediaspelare · Förlopp + Timer";
"live_activity.sample.no_icon.note" = "Ingen ikon och ingen färg, så förloppsindikatorn använder standardnyansen HA-blå. criticalText visas endast i den kompakta versionen av Dynamic Island.";
"live_activity.sample.no_icon.summary" = "En förloppsindikator i standardfärgen, utan ikon.";
"live_activity.sample.no_icon.title" = "Ingen ikon · Standardfärg";
"live_activity.sample.plain.note" = "Minimal fungerande layout – endast meddelandefältet är inställt. Kontrollerar att den enklaste layouten visas utan ikon, förloppsindikator eller timer.";
"live_activity.sample.plain.summary" = "Ett enkelt meddelande utan något annat.";
"live_activity.sample.plain.title" = "Vanligt meddelande";
"live_activity.sample.progress_direction.note" = "progress_bar_direction: decreasing flips the bar's fill: it shows what remains (progress_max − progress) and drains as progress rises. Percent text still shows the raw progress value. Also works on timer bars, e.g. increasing makes a countdown fill up instead of drain.";
"live_activity.sample.progress_direction.summary" = "A progress bar that drains instead of fills.";
"live_activity.sample.progress_direction.title" = "Battery · Decreasing Bar";
"live_activity.sample.rate_limit.note" = "Sex uppdateringar med 2 sekunders mellanrum. I iOS 18 visar systemet ungefär en var 15:e sekund – vissa utelämnas utan att man märker det och räknaren hoppar över. I simulatorn och i iOS 17 visas alla sex.";
"live_activity.sample.rate_limit.summary" = "Snabba uppdateringar efter varandra för att testa hur många som visas.";
"live_activity.sample.rate_limit.title" = "Begränsning av uppdateringsfrekvens · 6 snabba uppdateringar";
"live_activity.sample.security.note" = "Ingen förloppsindikator – statusen förmedlas enbart genom färg och ikon. Övergår från orange (rörelse) → rött (person) → grönt (allt klart).";
"live_activity.sample.security.summary" = "Ett säkerhetvarning som eskalerade, sedan gavs klartecken.";
"live_activity.sample.security.title" = "Säkerhetseskalering · Färg + ikon";
"live_activity.sample.washing.note" = "Processen genomgår fem namngivna steg; criticalText visar vilket steg man befinner sig i. Ikonen ändras till en bock när steget är klart.";
"live_activity.sample.washing.summary" = "Ett tvättprogram som går igenom alla sina olika steg.";
"live_activity.sample.washing.title" = "Tvättmaskin · Etiketter för tvättsteg";
